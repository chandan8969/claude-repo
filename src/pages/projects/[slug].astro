---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { content } = await project.render();
---

<Layout title={`${project.data.title} | Portfolio`}>
  <div class="max-w-3xl mx-auto">
    <a href="/" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors inline-block mb-8">
      &larr; Back to Gallery
    </a>

    <header class="mb-12">
      <div class="flex justify-between items-start mb-4">
        <h1 class="text-4xl font-extrabold text-slate-900">{project.data.title}</h1>
        <a
          href={project.data.githubLink}
          target="_blank"
          class="px-4 py-2 bg-slate-900 text-white rounded-lg text-sm font-medium hover:bg-slate-800 transition-colors"
        >
          View on GitHub
        </a>
      </div>
      <div class="flex flex-wrap gap-2 items-center">
        <span class="text-xs font-bold px-2 py-1 bg-indigo-100 text-indigo-700 rounded-full uppercase tracking-wider mr-2">
          {project.data.category.replace('-', ' ')}
        </span>
        <span class="text-sm text-slate-500">{project.data.date.toDateString()}</span>
      </div>
    </header>

    <div class="prose prose-slate max-w-none bg-white p-8 rounded-2xl border border-slate-200 shadow-sm">
      <div class="text-slate-600 mb-8 text-lg leading-relaxed">
        {project.data.description}
      </div>
      <div class="markdown-content">
        <div set:html={content} />
      </div>
    </div>

    <!-- View Counter Component -->
    <div class="mt-8 p-4 bg-slate-100 rounded-xl flex items-center gap-3 text-sm text-slate-600 font-medium">
      <span class="flex h-2 w-2 rounded-full bg-indigo-500 animate-pulse"></span>
      <span>Project views: <span id="view-count">...</span></span>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-200 flex flex-wrap gap-2">
      {project.data.tags.map(tag => (
        <span class="text-xs px-3 py-1 bg-slate-100 text-slate-600 rounded-full font-medium">{tag}</span>
      ))}
    </div>
  </div>

  <script is:inline define:vars={{ slug: project.slug }}>
    async function updateViews() {
      try {
        const response = await fetch(`/api/projects/${slug}/view`);
        const data = await response.json();
        document.getElementById('view-count').textContent = data.views;
      } catch (e) {
        console.error('Error fetching views:', e);
        document.getElementById('view-count').textContent = 'Error';
      }
    }
    updateViews();
  </script>
</Layout>
