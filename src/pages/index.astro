---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const categories = {
  'backend-java': 'Backend & Enterprise (Java)',
  'scripting-py': 'Scripting & Automation (Python)',
  'explorations': 'Learning & Explorations',
};
---

<Layout title="Project Portfolio | chandan8969">
  <header class="mb-16">
    <h1 class="text-4xl font-extrabold text-slate-900 mb-4">Project Showcase</h1>
    <p class="text-lg text-slate-600 max-w-2xl">
      Exploring the intersection of robust backend systems and agile automation.
      Welcome to my collection of work across Java, Python, and various technical experiments.
    </p>
  </header>

  <div class="space-y-16">
    {Object.entries(categories).map(([id, label]) => {
      const filteredProjects = projects.filter(p => p.data.category === id);
      if (filteredProjects.length === 0) return null;

      return (
        <section>
          <h2 class="text-2xl font-bold text-slate-800 mb-6 pb-2 border-b border-slate-200">{label}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {filteredProjects.map(project => (
              <a
                href={`/projects/${project.slug}`}
                class="group p-6 bg-white rounded-2xl border border-slate-200 hover:border-indigo-400 hover:shadow-lg transition-all duration-300"
              >
                <div class="flex justify-between items-start mb-4">
                  <h3 class="text-xl font-bold group-hover:text-indigo-600 transition-colors">{project.data.title}</h3>
                  <span class="text-xs font-medium px-2 py-1 bg-indigo-50 text-indigo-600 rounded-full uppercase tracking-wider">
                    {project.data.category.replace('-', ' ')}
                  </span>
                </div>
                <p class="text-slate-600 mb-6 line-clamp-2">{project.data.description}</p>
                <div class="flex flex-wrap gap-2">
                  {project.data.tags.map(tag => (
                    <span class="text-xs px-2 py-1 bg-slate-100 text-slate-500 rounded-md">{tag}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>

  <div class="mt-24 text-center p-12 bg-indigo-600 rounded-3xl text-white shadow-xl shadow-indigo-200">
    <h2 class="text-3xl font-bold mb-4">Want to collaborate?</h2>
    <p class="text-indigo-100 mb-8 text-lg">I'm always open to interesting projects and technical discussions.</p>
    <a href="/contact" class="px-8 py-3 bg-white text-indigo-600 font-bold rounded-full hover:bg-indigo-50 transition-all transform hover:scale-105 inline-block">
      Send me a message
    </a>
  </div>
</Layout>
